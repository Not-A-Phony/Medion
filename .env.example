# ============================================================
#  Medion Backend — Environment Template
#  Copy this file to `.env` and fill in real values.
#  `.env` is gitignored — never commit real secrets.
# ============================================================

# --- Database ---
# Local: full JDBC URL. On Render, DATABASE_URL is injected automatically
# and accepts the postgres://user:pass@host/db form.
DB_URL=jdbc:postgresql://localhost:5432/hardware_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Redis (optional) ---
# The subscription payment flow uses an in-memory cache and does NOT
# require Redis. Only set these if you enable Redis-backed caching.
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security ---
# Generate a secure 256-bit hex string for production:
#   openssl rand -hex 32
JWT_SECRET=replace_with_a_secure_256_bit_hex_string
# Key used for encrypting sensitive stored data (e.g. bank accounts)
APP_ENCRYPTION_KEY=replace_with_a_secure_key

# --- Cloudinary (image storage) ---
# Get these from https://cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- M-Pesa Daraja API ---
# Register an app at https://developer.safaricom.co.ke to obtain these.
# Sandbox test credentials work out of the box for development.
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_PASSKEY=your_daraja_passkey
MPESA_SHORTCODE=174379

# false = Safaricom sandbox, true = live/production
MPESA_IS_LIVE=false

# --- M-Pesa callback URLs ---
# MUST be a publicly reachable HTTPS URL. Safaricom cannot reach localhost —
# use your deployed domain, or a tunnel (e.g. ngrok) during local testing.
# Legacy order/webhook callback (raw Daraja nested JSON):
APP_PAYMENT_CALLBACK_URL=https://your-domain.onrender.com/api/v1/payments/mpesa-webhook
# New subscription STK callback (structured DTO):
APP_STK_CALLBACK_URL=https://your-domain.onrender.com/api/v1/payments/mpesa/callback
